@using TechVisionMaroc.Models
@{
    ViewData["Title"] = "Mes devis";
    var devis = (List<Devis>)ViewBag.Devis;

    string LibelleStatut(StatutDevis s) => s switch {
        StatutDevis.EnAttente => "En attente de réponse",
        StatutDevis.Repondu   => "Devis reçu — à valider",
        StatutDevis.Accepte   => "Accepté",
        StatutDevis.Refuse    => "Refusé",
        StatutDevis.Expire    => "Expiré",
        _ => s.ToString()
    };
    string CouleurStatut(StatutDevis s) => s switch {
        StatutDevis.EnAttente => "warning",
        StatutDevis.Repondu   => "primary",
        StatutDevis.Accepte   => "success",
        StatutDevis.Refuse    => "danger",
        StatutDevis.Expire    => "secondary",
        _ => "dark"
    };
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Compte" class="text-decoration-none">Mon compte</a></li>
            <li class="breadcrumb-item active">Mes devis</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h2 class="fw-bold mb-1"><i class="fas fa-file-invoice text-warning me-2"></i>Mes demandes de devis</h2>
        <p class="text-muted">Suivez vos demandes de prix personnalisés pour vos achats professionnels</p>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

    @if (!devis.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-file-invoice fa-3x text-muted mb-3"></i>
                <h5>Aucune demande de devis</h5>
                <p class="text-muted">Pour les commandes importantes, demandez un devis personnalisé.</p>
                <a href="/Catalogue" class="btn btn-primary">Parcourir le catalogue</a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>N° Devis</th>
                            <th>Date</th>
                            <th>Lignes</th>
                            <th>Montant</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in devis)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@d.NumeroDevis</td>
                                <td><small>@d.DateCreation.ToLocalTime().ToString("dd/MM/yyyy")</small></td>
                                <td>@d.Lignes.Count</td>
                                <td>
                                    @if (d.MontantPropose.HasValue)
                                    {
                                        <span class="fw-bold">@d.MontantPropose.Value.ToString("N0") MAD</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td><span class="badge bg-@CouleurStatut(d.Statut)">@LibelleStatut(d.Statut)</span></td>
                                <td>
                                    <a href="/Compte/devis/@d.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>Voir
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
