@model TechVisionMaroc.Models.Utilisateur

@{
    ViewData["Title"] = "Mon Profil";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Infos utilisateur -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:80px;height:80px;font-size:2rem;">
                        <i class="fas fa-user"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@Model.Prenom @Model.Nom</h5>
                    <p class="text-muted mb-2">@Model.Email</p>
                    @if (Model.Role == "Admin")
                    {
                        <span class="badge bg-warning text-dark"><i class="fas fa-crown me-1"></i>Administrateur</span>
                    }
                    else
                    {
                        <span class="badge bg-primary"><i class="fas fa-user me-1"></i>Client</span>
                    }
                    <hr />
                    <ul class="list-unstyled text-start small text-muted">
                        @if (!string.IsNullOrEmpty(Model.Telephone))
                        {
                            <li class="mb-1"><i class="fas fa-phone me-2"></i>@Model.Telephone</li>
                        }
                        @if (!string.IsNullOrEmpty(Model.Ville))
                        {
                            <li class="mb-1"><i class="fas fa-map-marker-alt me-2"></i>@Model.Ville</li>
                        }
                        <li class="mb-1"><i class="fas fa-calendar me-2"></i>Membre depuis @Model.DateInscription.ToString("MMMM yyyy")</li>
                        @if (Model.DerniereConnexion.HasValue)
                        {
                            <li><i class="fas fa-clock me-2"></i>Dernière connexion @Model.DerniereConnexion.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</li>
                        }
                    </ul>
                    <a href="/Account/ModifierProfil" class="btn btn-primary btn-sm w-100 mt-2">
                        <i class="fas fa-user-edit me-1"></i>Modifier mes informations
                    </a>
                    @if (Model.Role == "Admin")
                    {
                        var adminUrl = "/" + (Context.RequestServices.GetService<IConfiguration>()!["Admin:RoutePrefix"] ?? "admin");
                        <a href="@adminUrl" class="btn btn-warning btn-sm w-100 mt-2">
                            <i class="fas fa-cog me-1"></i>Panneau Admin
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Commandes -->
        <div class="col-md-8">
            <h4 class="fw-bold mb-3"><i class="fas fa-box me-2"></i>Mes Commandes</h4>
            @if (!Model.Commandes.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>Vous n'avez pas encore de commandes.
                    <a href="/Catalogue" class="alert-link ms-1">Parcourir le catalogue</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>N° Commande</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cmd in Model.Commandes.OrderByDescending(c => c.DateCommande))
                            {
                                <tr>
                                    <td><strong>@cmd.NumeroCommande</strong></td>
                                    <td>@cmd.DateCommande.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var badgeClass = cmd.Statut switch {
                                                TechVisionMaroc.Models.StatutCommande.EnAttente => "bg-warning text-dark",
                                                TechVisionMaroc.Models.StatutCommande.Confirmee => "bg-info",
                                                TechVisionMaroc.Models.StatutCommande.Expediee => "bg-primary",
                                                TechVisionMaroc.Models.StatutCommande.Livree => "bg-success",
                                                TechVisionMaroc.Models.StatutCommande.Annulee => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@cmd.Statut</span>
                                    </td>
                                    <td>@cmd.Total.ToString("N2") MAD</td>
                                    <td>
                                        <a href="/Commande/Details/@cmd.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
