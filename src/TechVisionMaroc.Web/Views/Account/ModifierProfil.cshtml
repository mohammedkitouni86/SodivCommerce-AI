@model TechVisionMaroc.Models.Utilisateur
@{
    ViewData["Title"] = "Modifier mon profil";
}

<div class="container py-5" style="max-width:800px">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Account/Profil" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h3 class="fw-bold mb-0"><i class="fas fa-user-edit text-primary me-2"></i>Modifier mes informations</h3>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]</div>
    }

    <!-- Informations personnelles -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">
            <i class="fas fa-id-card text-primary me-2"></i>Informations personnelles
        </div>
        <div class="card-body p-4">
            <form method="post" action="/Account/ModifierProfil">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                        <input type="text" name="prenom" class="form-control" value="@Model.Prenom" required maxlength="100" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                        <input type="text" name="nom" class="form-control" value="@Model.Nom" required maxlength="100" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control" value="@Model.Email" required maxlength="200" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Téléphone</label>
                        <input type="tel" name="telephone" class="form-control" value="@Model.Telephone" maxlength="30" placeholder="+212 6XX-XXXXXX" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Adresse</label>
                        <input type="text" name="adresse" class="form-control" value="@Model.Adresse" maxlength="300" placeholder="Rue, numéro..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Ville</label>
                        <input type="text" name="ville" class="form-control" value="@Model.Ville" maxlength="100" placeholder="Casablanca, Rabat..." />
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-2"></i>Enregistrer les modifications
                    </button>
                    <a href="/Account/Profil" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Changement de mot de passe -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold">
            <i class="fas fa-lock text-warning me-2"></i>Changer mon mot de passe
        </div>
        <div class="card-body p-4">
            <form method="post" action="/Account/ChangerMotDePasse">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Mot de passe actuel <span class="text-danger">*</span></label>
                        <input type="password" name="motDePasseActuel" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nouveau mot de passe <span class="text-danger">*</span></label>
                        <input type="password" name="nouveauMotDePasse" class="form-control" required minlength="8" />
                        <div class="form-text">Min. 8 caractères, 1 majuscule, 1 minuscule, 1 chiffre.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Confirmation <span class="text-danger">*</span></label>
                        <input type="password" name="confirmation" class="form-control" required minlength="8" />
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="fas fa-key me-2"></i>Changer le mot de passe
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
