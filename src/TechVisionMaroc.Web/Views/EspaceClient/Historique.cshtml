@{
    ViewData["Title"] = "Historique de navigation";
    var historique = ViewBag.Historique as System.Collections.IEnumerable;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Compte" class="text-decoration-none">Mon compte</a></li>
            <li class="breadcrumb-item active">Historique</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-history text-info me-2"></i>Historique de navigation</h2>
            <p class="text-muted mb-0">Les produits que vous avez consultés ces 90 derniers jours</p>
        </div>
        <form method="post" action="/Compte/historique/effacer" onsubmit="return confirm('Effacer tout votre historique ?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="fas fa-trash me-1"></i>Tout effacer
            </button>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @{
        var liste = historique?.Cast<dynamic>().ToList() ?? new List<dynamic>();
    }
    @if (!liste.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-eye-slash fa-3x text-muted mb-3"></i>
                <h5>Aucun historique pour le moment</h5>
                <p class="text-muted">Parcourez le catalogue, vos consultations apparaîtront ici.</p>
                <a href="/Catalogue" class="btn btn-primary">Découvrir le catalogue</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (dynamic h in liste)
            {
                var p = (TechVisionMaroc.Models.Produit)h.Produit;
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100 hover-lift">
                        <a href="/Produit/Details/@p.Id" class="text-decoration-none">
                            <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/images/placeholder.png" : p.ImageUrl)"
                                 class="card-img-top" style="height:160px;object-fit:cover;" alt="@p.Nom" />
                        </a>
                        <div class="card-body p-3">
                            <small class="text-muted">@p.Categorie?.Nom</small>
                            <h6 class="fw-semibold mt-1 mb-2 text-truncate">
                                <a href="/Produit/Details/@p.Id" class="text-dark text-decoration-none">@p.Nom</a>
                            </h6>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-primary">@((p.PrixPromo ?? p.Prix).ToString("N0")) MAD</span>
                                <small class="text-muted">
                                    <i class="fas fa-eye me-1"></i>@h.NbVues
                                </small>
                            </div>
                            <small class="text-muted d-block mt-1">
                                <i class="fas fa-clock me-1"></i>@(((DateTime)h.DerniereVue).ToLocalTime().ToString("dd/MM HH:mm"))
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
