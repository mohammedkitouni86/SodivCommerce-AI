@{ ViewData["Title"] = "Mon compte"; }

<div class="container py-5">
    <h2 class="fw-bold mb-1">Bonjour @Context.Session.GetString("UtilisateurNom") 👋</h2>
    <p class="text-muted mb-4">Bienvenue dans votre espace personnel SODIV Bureau.</p>

    <div class="row g-3">
        @{
            var cards = new[] {
                new { Url="/Account/Profil",           Icon="fa-user",        Color="primary",  Title="Profil",            Count=(int?)null,                    Desc="Mes informations" },
                new { Url="/Account/Profil",           Icon="fa-shopping-bag",Color="success",  Title="Commandes",         Count=(int?)ViewBag.NbCommandes,     Desc="Mes achats" },
                new { Url="/Wishlist",                 Icon="fa-heart",       Color="danger",   Title="Favoris",           Count=(int?)ViewBag.NbWishlist,      Desc="Ma liste de souhaits" },
                new { Url="/Compte/historique",        Icon="fa-history",     Color="info",     Title="Historique",        Count=(int?)null,                    Desc="Produits consultés" },
                new { Url="/Compte/adresses",          Icon="fa-map-marker-alt",Color="warning",Title="Adresses",          Count=(int?)ViewBag.NbAdresses,      Desc="Carnet d'adresses" },
                new { Url="/Compte/coupons",           Icon="fa-ticket-alt",  Color="success",  Title="Mes coupons",       Count=(int?)ViewBag.NbCoupons,       Desc="Codes promo disponibles" },
                new { Url="/Compte/messages",          Icon="fa-comments",    Color="primary",  Title="Messages",          Count=(int?)ViewBag.NbMessages,      Desc="Centre de messagerie" },
                new { Url="/Compte/abonnements",       Icon="fa-redo",        Color="info",     Title="Abonnements",       Count=(int?)ViewBag.NbAbonnements,   Desc="Subscribe & Save" },
                new { Url="/Compte/devis",             Icon="fa-file-invoice",Color="warning",  Title="Mes devis",         Count=(int?)ViewBag.NbDevis,         Desc="Demandes de devis" },
                new { Url="/compte/fidelite",         Icon="fa-coins",       Color="warning",  Title="Fidélité",          Count=(int?)null,                    Desc="Points & récompenses" },
                new { Url="/Home/Parrainage",          Icon="fa-gift",        Color="primary",  Title="Parrainage",        Count=(int?)null,                    Desc="Invitez vos amis" },
            };
        }
        @foreach (var c in cards)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <a href="@c.Url" class="card border-0 shadow-sm h-100 text-decoration-none hover-lift">
                    <div class="card-body text-center p-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 bg-@c.Color bg-opacity-10" style="width:64px;height:64px;">
                            <i class="fas @c.Icon fa-2x text-@c.Color"></i>
                        </div>
                        <h6 class="fw-bold mb-1 text-dark">@c.Title</h6>
                        @if (c.Count.HasValue)
                        {
                            <div class="h4 fw-bold text-@c.Color mb-1">@c.Count</div>
                        }
                        <small class="text-muted">@c.Desc</small>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
