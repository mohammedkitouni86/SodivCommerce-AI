@using TechVisionMaroc.Models
@{
    ViewData["Title"] = "Carnet d'adresses";
    var adresses = (List<AdresseClient>)ViewBag.Adresses;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Compte" class="text-decoration-none">Mon compte</a></li>
            <li class="breadcrumb-item active">Adresses</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-map-marker-alt text-warning me-2"></i>Carnet d'adresses</h2>
            <p class="text-muted mb-0">Gérez vos adresses de livraison (siège, filiales, magasin…)</p>
        </div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjouterAdresse">
            <i class="fas fa-plus me-1"></i>Nouvelle adresse
        </button>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

    @if (!adresses.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-map-marker-alt fa-3x text-muted mb-3"></i>
                <h5>Aucune adresse enregistrée</h5>
                <p class="text-muted">Ajoutez une première adresse pour faciliter vos commandes futures.</p>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjouterAdresse">
                    <i class="fas fa-plus me-1"></i>Ajouter une adresse
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var a in adresses)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 @(a.ParDefaut ? "border-primary border-2" : "")">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0">
                                    <i class="fas fa-map-marker-alt text-primary me-1"></i>@a.Libelle
                                </h6>
                                @if (a.ParDefaut)
                                {
                                    <span class="badge bg-primary">Par défaut</span>
                                }
                            </div>
                            <div class="small">
                                <div class="fw-semibold">@a.DestinataireNom</div>
                                <div class="text-muted">@a.Telephone</div>
                                <div class="mt-2">
                                    @a.Adresse<br />
                                    @a.CodePostal @a.Ville
                                    @if (!string.IsNullOrWhiteSpace(a.Complement)) { <br/><small class="text-muted">@a.Complement</small> }
                                </div>
                            </div>
                            <div class="mt-3 d-flex gap-2">
                                @if (!a.ParDefaut)
                                {
                                    <form method="post" action="/Compte/adresses/defaut/@a.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-star me-1"></i>Par défaut
                                        </button>
                                    </form>
                                }
                                <form method="post" action="/Compte/adresses/supprimer/@a.Id" class="d-inline"
                                      onsubmit="return confirm('Supprimer cette adresse ?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal ajouter -->
<div class="modal fade" id="modalAjouterAdresse" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form method="post" action="/Compte/adresses/ajouter">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-map-marker-alt me-2"></i>Nouvelle adresse</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Libellé *</label>
                            <input type="text" name="Libelle" class="form-control" required maxlength="80" placeholder="ex: Bureau principal" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Destinataire *</label>
                            <input type="text" name="DestinataireNom" class="form-control" required maxlength="100" placeholder="Nom de la personne" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Téléphone *</label>
                            <input type="tel" name="Telephone" class="form-control" required maxlength="20" placeholder="+212 6XX XXX XXX" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ville *</label>
                            <input type="text" name="Ville" class="form-control" required maxlength="80" placeholder="Casablanca" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label fw-semibold">Adresse *</label>
                            <input type="text" name="Adresse" class="form-control" required maxlength="250" placeholder="Numéro et rue" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Code postal</label>
                            <input type="text" name="CodePostal" class="form-control" maxlength="20" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Complément (étage, code…)</label>
                            <input type="text" name="Complement" class="form-control" maxlength="300" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="parDefaut" value="true" id="parDefaut" class="form-check-input" />
                                <label for="parDefaut" class="form-check-label">Définir comme adresse par défaut</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>
