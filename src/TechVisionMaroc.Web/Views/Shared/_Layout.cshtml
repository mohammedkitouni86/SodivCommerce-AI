@if (Context.Session.GetInt32("UtilisateurId") != null)
{
    <!-- Déconnexion automatique après 30 min d'inactivité -->
    <script>
    (function () {
        const TIMEOUT_MS = 30 * 60 * 1000; // 30 minutes
        const WARN_MS    = 2  * 60 * 1000; // avertissement 2 min avant
        let timerLogout, timerWarn;
        const modal = creerModal();

        function reset() {
            clearTimeout(timerLogout);
            clearTimeout(timerWarn);
            timerWarn   = setTimeout(avertir,   TIMEOUT_MS - WARN_MS);
            timerLogout = setTimeout(deconnecter, TIMEOUT_MS);
        }

        function avertir() {
            modal.show();
        }

        function deconnecter() {
            modal.hide();
            try { localStorage.removeItem('sodiva_chat_hist'); } catch {}
            window.location.href = '/Account/Deconnexion?raison=inactivite';
        }

        function creerModal() {
            const div = document.createElement('div');
            div.innerHTML = `
              <div class="modal fade" id="modalInactivite" tabindex="-1" data-bs-backdrop="static">
                <div class="modal-dialog modal-sm modal-dialog-centered">
                  <div class="modal-content border-warning">
                    <div class="modal-header bg-warning text-dark">
                      <h6 class="modal-title"><i class="fas fa-clock me-2"></i>Session bientôt expirée</h6>
                    </div>
                    <div class="modal-body text-center py-3">
                      <p class="mb-2">Vous serez déconnecté dans <strong>2 minutes</strong> par inactivité.</p>
                      <button class="btn btn-primary btn-sm" onclick="continuerSession()">
                        <i class="fas fa-check me-1"></i>Je suis là
                      </button>
                    </div>
                  </div>
                </div>
              </div>`;
            document.body.appendChild(div);
            return new bootstrap.Modal(document.getElementById('modalInactivite'));
        }

        window.continuerSession = function () {
            modal.hide();
            reset();
            fetch('/Account/Ping', { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' } }).catch(() => {});
        };

        ['mousemove','keydown','click','scroll','touchstart'].forEach(e =>
            document.addEventListener(e, reset, { passive: true })
        );

        reset();
    })();
    </script>
}
