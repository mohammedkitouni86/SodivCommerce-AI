<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} | SODIV Bureau" : "SODIV Bureau – Matériel Informatique & Fournitures de Bureau")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "SODIV Bureau – Votre partenaire technologique au Maroc. Ordinateurs, imprimantes, réseaux et fournitures de bureau.")" />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=@DateTime.Now.Ticks" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png?v=@DateTime.Now.Ticks" />
    <link rel="shortcut icon" href="/images/favicon.ico?v=@DateTime.Now.Ticks" />

    <!-- Bootstrap 5 (local) -->
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome (local) -->
    <link href="/lib/fontawesome/css/all.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link href="/css/site.css?v=@DateTime.Now.Ticks" rel="stylesheet" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest?v=8" />
    <meta name="theme-color" content="#0d6efd" />
    <link rel="apple-touch-icon" href="/images/icon-192.png?v=8" />

    @RenderSection("MetaTags", required: false)
    @RenderSection("Styles", required: false)
</head>
<body>

@inject IPrixService Prix
@inject IWishlistService WishlistSvc
@{
    var uidLayout = Context.Session.GetInt32("UtilisateurId");
    int wishlistCountLayout = 0;
    if (uidLayout != null)
    {
        try { wishlistCountLayout = await WishlistSvc.CompterAsync(uidLayout.Value); } catch {}
    }
}

<!-- Bannière promo top -->
<div class="bg-warning text-dark py-2 text-center small fw-semibold">
    <i class="fas fa-truck me-1"></i> Livraison <strong>GRATUITE</strong> à partir de 1 000 MAD
    &nbsp;·&nbsp; <i class="fas fa-tag me-1"></i> Code promo <code class="bg-dark text-warning px-2 rounded">SODIV10</code> = -10%
    &nbsp;·&nbsp; <a href="/Home/Promotions" class="text-dark fw-bold text-decoration-underline">Voir les offres</a>
</div>

<!-- Topbar — bandeau défilant (marquee) -->
<div class="topbar py-2 bg-primary text-white overflow-hidden">
    <div class="topbar-track">
        @{ var sep = "<span class=\"mx-4 text-warning\">●</span>"; }
        @{ var content = $@"
            <span><i class='fas fa-handshake me-2 text-warning'></i><strong>+500 clients</strong> nous font confiance au Maroc</span>{sep}
            <span><i class='fas fa-truck-fast me-2 text-warning'></i>Livraison <strong>GRATUITE</strong> dès 1 000 MAD partout au Maroc</span>{sep}
            <span><i class='fas fa-shield-alt me-2 text-warning'></i>Paiement <strong>100% sécurisé</strong> via CMI &middot; SSL 256 bits</span>{sep}
            <span><i class='fas fa-undo-alt me-2 text-warning'></i>Satisfait ou remboursé sous <strong>7 jours</strong></span>{sep}
            <span><i class='fas fa-gift me-2 text-warning'></i>Parrainez un ami &middot; gagnez <strong>50 MAD</strong> chacun</span>{sep}
            <span><i class='fas fa-map-marker-alt me-2 text-warning'></i>Showroom à <strong>Salé</strong> &middot; Lundi-Samedi 9h-18h</span>{sep}
            <span><i class='fas fa-headset me-2 text-warning'></i>Support <strong>WhatsApp</strong> &middot; réponse sous 24h</span>{sep}
        "; }
        <div class="topbar-content">@Html.Raw(content)</div>
        <div class="topbar-content" aria-hidden="true">@Html.Raw(content)</div>
    </div>
</div>
<style>
.topbar { font-size: .9rem; }
.topbar-track {
    display: flex;
    width: max-content;
    animation: topbarScroll 40s linear infinite;
}
.topbar-track:hover { animation-play-state: paused; }
.topbar-content {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 2rem;
}
@@keyframes topbarScroll {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
}
</style>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container-fluid px-3 px-lg-4">

        <!-- Bouton hamburger : menu catégories au survol -->
        <div class="hamburger-cats mega-menu-trigger me-2 d-none d-lg-block">
            <button type="button" class="hamburger-btn" aria-label="Catégories">
                <i class="fas fa-bars"></i>
            </button>
            @await Component.InvokeAsync("CategoriesMenu")
        </div>

        <a class="navbar-brand d-flex align-items-center fw-bold text-primary me-3" href="/">
            <img src="/images/logo-ag.png" alt="Sodiv Bureau — Tout pour le bureau"
                 style="height:48px;width:auto" />
        </a>

        <!-- Barre de recherche style Google -->
        <div class="d-none d-lg-flex flex-grow-1 mx-4">
            <form action="/recherche" method="get" class="w-100 position-relative" id="formRecherche">
                <div class="google-search">
                    <input type="text" name="q" id="searchInput"
                           placeholder="@T.Get("Rechercher")" autocomplete="off"
                           value="@Context.Request.Query["q"]" />
                    <div class="google-search-icons">
                        <button type="button" id="btnMicroBarre" class="gs-icon" title="Recherche vocale" aria-label="Recherche vocale">
                            <i class="fas fa-microphone"></i>
                        </button>
                        <span class="gs-sep"></span>
                        <button type="button" id="btnRechercheImage" class="gs-icon" title="Recherche par image" aria-label="Recherche par image">
                            <i class="fas fa-camera"></i>
                        </button>
                        <input type="file" id="fileRechercheImage" accept="image/*" class="d-none" />
                        <button type="submit" class="gs-icon gs-search" title="Rechercher" aria-label="Rechercher">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div id="autocompleteResults" class="autocomplete-dropdown d-none"></div>
            </form>
        </div>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="/">@T.Get("Accueil")</a></li>
                <li class="nav-item">
                    <a class="nav-link" href="/Catalogue">@T.Get("Produits")</a>
                </li>

                <li class="nav-item"><a class="nav-link" href="/Home/Contact">@T.Get("Contact")</a></li>

                @{
                    var roleNav = Context.Session.GetString("UtilisateurRole");
                }

                @if (Context.Session.GetInt32("UtilisateurId") != null)
                {
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/wishlist" title="Ma liste de souhaits">
                            <i class="fas fa-heart fs-5 text-danger"></i>
                            @{
                                var wlCount = wishlistCountLayout;
                                if (wlCount > 0)
                                {
                                    <span id="wishlistCountBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">@wlCount</span>
                                }
                                else
                                {
                                    <span id="wishlistCountBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                                }
                            }
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link position-relative" href="/Panier">
                        <i class="fas fa-shopping-cart fs-5"></i>
                        @{
