@model TechVisionMaroc.Models.Categorie

<form method="post" action="@ViewBag.AdminBase/categories/@Model.Id/image"
      enctype="multipart/form-data" class="row g-3 align-items-center">
    @Html.AntiForgeryToken()

    <!-- Aperçu -->
    <div class="col-auto">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="cat-image-preview" alt="@Model.Nom" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="cat-image-empty" style="display:none">
                <i class="fas @Model.IconeClass"></i>
            </div>
        }
        else
        {
            <div class="cat-image-empty">
                <i class="fas @Model.IconeClass"></i>
            </div>
        }
    </div>

    <!-- Infos -->
    <div class="col-md-3">
        <div class="fw-bold">@Model.Nom</div>
        <small class="text-muted">@(Model.ParentId == null ? "Catégorie principale" : "Sous-catégorie")</small>
    </div>

    <!-- URL image -->
    <div class="col-md-4">
        <label class="small text-muted mb-1">URL de l'image (ou upload ci-dessous)</label>
        <input type="text" name="imageUrl" value="@Model.ImageUrl" class="form-control form-control-sm"
               placeholder="https://... ou /images/categories/..." />
    </div>

    <!-- Upload fichier -->
    <div class="col-md-3">
        <label class="small text-muted mb-1">Ou uploader un fichier</label>
        <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" />
    </div>

    <!-- Actions -->
    <div class="col-md-1 d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm" title="Enregistrer">
            <i class="fas fa-save"></i>
        </button>
    </div>
</form>
