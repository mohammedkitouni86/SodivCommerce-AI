@using Microsoft.Extensions.Configuration
@inject IConfiguration Cfg
@{ ViewData["Title"] = "Mentions légales"; var s = Cfg.GetSection("Societe"); }

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="text-center mb-5">
                <i class="fas fa-balance-scale fa-3x text-primary mb-3"></i>
                <h1 class="fw-bold">Mentions légales</h1>
                <p class="text-muted">Informations relatives à l'éditeur du site</p>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">

                    <h4 class="fw-bold text-primary">Éditeur du site</h4>
                    <table class="table table-borderless">
                        <tbody>
                            <tr><th style="width:200px;">Raison sociale</th><td>@s["Nom"] SARL</td></tr>
                            <tr><th>Forme juridique</th><td>Société à Responsabilité Limitée</td></tr>
                            <tr><th>Capital social</th><td>@s["Capital"] MAD</td></tr>
                            <tr><th>Adresse</th><td>@s["Adresse"], @s["Ville"] @s["CodePostal"], @s["Pays"]</td></tr>
                            <tr><th>Téléphone</th><td>@s["Telephone"]</td></tr>
                            <tr><th>Email</th><td><a href="mailto:@s["Email"]">@s["Email"]</a></td></tr>
                            <tr><th>Site web</th><td>@s["SiteWeb"]</td></tr>
                        </tbody>
                    </table>

                    <h4 class="fw-bold text-primary mt-4">Informations légales</h4>
                    <table class="table table-borderless">
                        <tbody>
                            <tr><th style="width:200px;">ICE</th><td>@s["ICE"]</td></tr>
                            <tr><th>Registre de Commerce (RC)</th><td>@s["RC"] – Tribunal de Rabat</td></tr>
                            <tr><th>Identifiant Fiscal (IF)</th><td>@s["IF"]</td></tr>
                            <tr><th>Taxe Professionnelle (TP)</th><td>@s["TP"]</td></tr>
                            <tr><th>CNSS</th><td>@s["CNSS"]</td></tr>
                        </tbody>
                    </table>

                    <h4 class="fw-bold text-primary mt-4">Directeur de la publication</h4>
                    <p>Le directeur de la publication est le représentant légal de SODIV Bureau SARL.</p>

                    <h4 class="fw-bold text-primary mt-4">Hébergement</h4>
                    <p>Le site est hébergé sur des serveurs sécurisés en France (Union Européenne), conformes aux normes ISO 27001.</p>

                    <h4 class="fw-bold text-primary mt-4">Propriété intellectuelle</h4>
                    <p>L'ensemble du contenu de ce site (textes, images, logos, graphismes, vidéos) est protégé par le droit d'auteur marocain et international. Toute reproduction, même partielle, est strictement interdite sans autorisation écrite préalable de SODIV Bureau.</p>

                    <h4 class="fw-bold text-primary mt-4">Crédits</h4>
                    <p>Conception et développement : SODIV Bureau. Icônes : Font Awesome. Framework : ASP.NET Core &amp; Bootstrap 5.</p>

                    <hr class="my-4" />
                    <p class="text-muted small mb-0">Dernière mise à jour : @DateTime.Now.ToString("dd MMMM yyyy")</p>
                </div>
            </div>
        </div>
    </div>
</div>
