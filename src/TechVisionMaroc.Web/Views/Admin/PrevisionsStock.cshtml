@model List<TechVisionMaroc.Services.PrevisionStock>
@using TechVisionMaroc.Services
@{
    ViewData["Title"] = "Prévisions Stock IA";
    var c = ViewBag.Compteurs;
    string? filtre = ViewBag.NiveauFiltre as string;
    var baseUrl = (ViewBag.AdminBase as string) ?? "/admin";
    string Badge(NiveauAlerte n) => n switch
    {
        NiveauAlerte.Critique  => "bg-danger",
        NiveauAlerte.Attention => "bg-warning text-dark",
        NiveauAlerte.Ok        => "bg-success",
        NiveauAlerte.Surstock  => "bg-info text-dark",
        _                      => "bg-secondary"
    };
    string Libelle(NiveauAlerte n) => n switch
    {
        NiveauAlerte.Critique  => "Critique",
        NiveauAlerte.Attention => "Attention",
        NiveauAlerte.Ok        => "OK",
        NiveauAlerte.Surstock  => "Surstock",
        _                      => "Sans vente"
    };
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold"><i class="fas fa-chart-line text-primary me-2"></i>Prévisions Stock IA</h1>
            <p class="text-muted mb-0">Analyse comportementale sur 90 jours — vitesse de vente, tendance, jours de stock restants</p>
        </div>
        <a href="@baseUrl/produits" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Retour produits
        </a>
    </div>

    <!-- Cartes statistiques -->
    <div class="row g-3 mb-4">
        <div class="col-md">
            <a href="?niveau=Critique" class="text-decoration-none">
                <div class="card border-danger shadow-sm h-100 @(filtre == "Critique" ? "border-3" : "")">
                    <div class="card-body text-center">
                        <i class="fas fa-fire fa-2x text-danger mb-2"></i>
                        <div class="h2 fw-bold text-danger mb-0">@c.Critique</div>
                        <small class="text-muted">Critique (&lt; 7 j)</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md">
            <a href="?niveau=Attention" class="text-decoration-none">
                <div class="card border-warning shadow-sm h-100 @(filtre == "Attention" ? "border-3" : "")">
                    <div class="card-body text-center">
                        <i class="fas fa-exclamation-triangle fa-2x text-warning mb-2"></i>
                        <div class="h2 fw-bold text-warning mb-0">@c.Attention</div>
                        <small class="text-muted">Attention (7-14 j)</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md">
            <a href="?niveau=Ok" class="text-decoration-none">
                <div class="card border-success shadow-sm h-100 @(filtre == "Ok" ? "border-3" : "")">
                    <div class="card-body text-center">
                        <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                        <div class="h2 fw-bold text-success mb-0">@c.Ok</div>
                        <small class="text-muted">OK</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md">
            <a href="?niveau=Surstock" class="text-decoration-none">
                <div class="card border-info shadow-sm h-100 @(filtre == "Surstock" ? "border-3" : "")">
                    <div class="card-body text-center">
                        <i class="fas fa-boxes-stacked fa-2x text-info mb-2"></i>
                        <div class="h2 fw-bold text-info mb-0">@c.Surstock</div>
                        <small class="text-muted">Surstock</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md">
            <a href="?niveau=SansVente" class="text-decoration-none">
                <div class="card border-secondary shadow-sm h-100 @(filtre == "SansVente" ? "border-3" : "")">
                    <div class="card-body text-center">
                        <i class="fas fa-circle-pause fa-2x text-secondary mb-2"></i>
                        <div class="h2 fw-bold text-secondary mb-0">@c.SansVente</div>
                        <small class="text-muted">Sans vente</small>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(filtre))
    {
        <div class="mb-3">
            <a href="@baseUrl/previsions-stock" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-times me-1"></i>Retirer le filtre @filtre
            </a>
        </div>
    }

    <!-- Tableau -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Niveau</th>
                        <th>Produit</th>
                        <th class="text-end">Stock</th>
                        <th class="text-end">Ventes 90j</th>
                        <th class="text-end">Vitesse/j</th>
                        <th class="text-end">Jours restants</th>
                        <th class="text-end">Tendance</th>
                        <th class="text-end">À commander</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><span class="badge @Badge(p.Niveau)">@Libelle(p.Niveau)</span></td>
                            <td>
                                <div class="fw-semibold">@p.Nom</div>
                                <small class="text-muted">@p.Marque · @p.Categorie</small>
                            </td>
                            <td class="text-end fw-semibold">@p.StockActuel</td>
                            <td class="text-end">@p.VentesTotal90j</td>
                            <td class="text-end">@p.VentesParJour.ToString("F2")</td>
                            <td class="text-end">
                                @if (p.JoursRestants.HasValue)
                                {
                                    <span class="@(p.JoursRestants < 7 ? "text-danger fw-bold" : p.JoursRestants < 14 ? "text-warning fw-bold" : "")">
                                        @p.JoursRestants.Value.ToString("F0") j
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (p.TendancePct > 10)
                                {
                                    <span class="text-success"><i class="fas fa-arrow-trend-up me-1"></i>+@p.TendancePct.ToString("F0")%</span>
                                }
                                else if (p.TendancePct < -10)
                                {
                                    <span class="text-danger"><i class="fas fa-arrow-trend-down me-1"></i>@p.TendancePct.ToString("F0")%</span>
                                }
                                else
                                {
                                    <span class="text-muted">≈ @p.TendancePct.ToString("F0")%</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (p.QuantiteRecommandee > 0)
                                {
                                    <span class="badge bg-primary">+@p.QuantiteRecommandee</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="@baseUrl/produits/modifier/@p.ProduitId" class="btn btn-sm btn-outline-primary" title="Modifier">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">Aucun produit dans cette catégorie.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 small text-muted">
        <i class="fas fa-info-circle me-1"></i>
        Vitesse = moyenne unités/jour sur 90 derniers jours · Tendance = comparaison 45 derniers jours vs 45 jours précédents · À commander = pour couvrir 30 jours.
    </div>
</div>
