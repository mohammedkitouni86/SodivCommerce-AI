@model TechVisionMaroc.Models.Commande
@inject TechVisionMaroc.Services.ISuiviColisService SuiviSvc

@{
    ViewData["Title"] = $"Commande {Model.NumeroCommande}";
    var infoTransp = SuiviSvc.Info(Model.Transporteur);
    var urlSuiviExt = SuiviSvc.UrlSuivi(Model.Transporteur, Model.NumeroSuivi);

    var (badgeClass, icone) = Model.Statut switch {
        TechVisionMaroc.Models.StatutCommande.EnAttente     => ("bg-warning text-dark", "fa-clock"),
        TechVisionMaroc.Models.StatutCommande.Confirmee     => ("bg-info text-white",   "fa-check"),
        TechVisionMaroc.Models.StatutCommande.EnPreparation => ("bg-primary text-white","fa-cogs"),
        TechVisionMaroc.Models.StatutCommande.Expediee      => ("bg-primary text-white","fa-truck"),
        TechVisionMaroc.Models.StatutCommande.Livree        => ("bg-success text-white","fa-box-open"),
        TechVisionMaroc.Models.StatutCommande.Annulee       => ("bg-danger text-white", "fa-times-circle"),
        TechVisionMaroc.Models.StatutCommande.Remboursee    => ("bg-secondary text-white","fa-undo"),
        _                                                   => ("bg-secondary text-white","fa-question")
    };
}

<div class="bg-dark text-white py-3 border-bottom">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a href="/Account/Profil" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h5 class="mb-0 fw-bold"><i class="fas fa-box me-2 text-warning"></i>@Model.NumeroCommande</h5>
                <small class="text-muted">Passée le @Model.DateCommande.ToLocalTime().ToString("dd MMMM yyyy à HH:mm")</small>
            </div>
            <span class="badge @badgeClass ms-auto fs-6">
                <i class="fas @icone me-1"></i>@Model.Statut
            </span>
        </div>
    </div>
</div>

<div class="container py-4" style="max-width:900px">
    <div class="row g-4">

        <!-- Articles commandés -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fas fa-shopping-bag me-2 text-primary"></i>Articles commandés (@Model.Lignes.Count)
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var ligne in Model.Lignes)
                        {
                            <div class="list-group-item d-flex align-items-center gap-3 py-3 px-4">
                                <img src="@(string.IsNullOrEmpty(ligne.Produit?.ImageUrl) ? "/images/placeholder.svg" : ligne.Produit.ImageUrl)"
                                     alt="@ligne.Produit?.Nom"
                                     class="rounded"
                                     style="width:60px;height:60px;object-fit:contain;background:#f8f9fa;"
                                     onerror="this.src='/images/placeholder.svg'" />
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@ligne.Produit?.Nom</div>
                                    <div class="text-muted small">@ligne.Produit?.Marque</div>
                                    <div class="small text-muted">
                                        @ligne.PrixUnitaire.ToString("N2") MAD × @ligne.Quantite
                                    </div>
                                </div>
                                <div class="fw-bold text-end" style="min-width:90px">
                                    @ligne.SousTotal.ToString("N2") MAD
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Sous-total</span>
                        <span>@Model.SousTotal.ToString("N2") MAD</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted small mt-1">
                        <span>Frais de livraison</span>
                        <span>
                            @if (Model.FraisLivraison == 0)
                            {
                                <span class="text-success fw-semibold">Gratuit</span>
                            }
                            else
                            {
                                @Model.FraisLivraison.ToString("N2") <text>MAD</text>
                            }
                        </span>
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fw-bold fs-6">
                        <span>Total</span>
                        <span class="text-primary">@Model.Total.ToString("N2") MAD</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Infos livraison & paiement -->
        <div class="col-md-4">

            <!-- Livraison -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fas fa-map-marker-alt me-2 text-danger"></i>Livraison
                </div>
                <div class="card-body small">
                    <div class="mb-1"><i class="fas fa-road me-2 text-muted"></i>@Model.AdresseLivraison</div>
                    <div class="mb-1"><i class="fas fa-city me-2 text-muted"></i>@Model.VilleLivraison</div>
                    <div class="mb-1"><i class="fas fa-phone me-2 text-muted"></i>@Model.TelephoneLivraison</div>
                    @if (Model.DateLivraison.HasValue)
                    {
                        <div class="mt-2 text-success">
                            <i class="fas fa-check-circle me-1"></i>
                            Livré le @Model.DateLivraison.Value.ToLocalTime().ToString("dd/MM/yyyy")
                        </div>
                    }
                </div>
            </div>

            <!-- Paiement -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fas fa-credit-card me-2 text-success"></i>Paiement
                </div>
                <div class="card-body small">
                    @{
                        var (iconePay, labelPay) = Model.MethodePaiement switch {
                            TechVisionMaroc.Models.MethodePaiement.Stripe  => ("fa-stripe-s", "Stripe"),
                            TechVisionMaroc.Models.MethodePaiement.CMI     => ("fa-university", "CMI"),
                            TechVisionMaroc.Models.MethodePaiement.PayPal  => ("fa-paypal", "PayPal"),
                            TechVisionMaroc.Models.MethodePaiement.Especes => ("fa-money-bill-wave", "Espèces à la livraison"),
                            _                                               => ("fa-credit-card", Model.MethodePaiement.ToString())
                        };
                    }
                    <i class="fab @iconePay me-2"></i>@labelPay
                </div>
            </div>

            <!-- Notes -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="fas fa-sticky-note me-2 text-warning"></i>Notes
                    </div>
                    <div class="card-body small text-muted">
                        @Model.Notes
                    </div>
                </div>
            }

            <!-- Suivi colis transporteur -->
            @if (Model.Transporteur != TechVisionMaroc.Models.Transporteur.Aucun || !string.IsNullOrEmpty(Model.NumeroSuivi))
            {
                <div class="card border-0 shadow-sm mt-3">
                    <div class="card-header bg-@infoTransp.Couleur text-white fw-semibold">
                        <i class="fas @infoTransp.LogoIcone me-2"></i>@infoTransp.Nom
                    </div>
                    <div class="card-body small">
                        @if (!string.IsNullOrEmpty(Model.NumeroSuivi))
                        {
                            <div class="mb-2">
                                <div class="text-muted">N° de suivi</div>
                                <div class="fw-bold font-monospace">@Model.NumeroSuivi</div>
                            </div>
                        }
                        <a href="/suivi/@Model.NumeroCommande?key=@Model.NumeroSuivi"
                           class="btn btn-info btn-sm w-100 mb-2">
                            <i class="fas fa-route me-1"></i>Voir la timeline détaillée
                        </a>
                        @if (urlSuiviExt != null)
                        {
                            <a href="@urlSuiviExt" target="_blank" rel="noopener"
                               class="btn btn-outline-@infoTransp.Couleur btn-sm w-100">
                                <i class="fas fa-external-link-alt me-1"></i>Site @infoTransp.Nom
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Suivi statut -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fas fa-route me-2 text-info"></i>Suivi
                </div>
                <div class="card-body p-3">
                    @{
                        var etapes = new[] {
                            (TechVisionMaroc.Models.StatutCommande.EnAttente,     "En attente",      "fa-clock"),
                            (TechVisionMaroc.Models.StatutCommande.Confirmee,     "Confirmée",       "fa-check"),
                            (TechVisionMaroc.Models.StatutCommande.EnPreparation, "En préparation",  "fa-cogs"),
                            (TechVisionMaroc.Models.StatutCommande.Expediee,      "Expédiée",        "fa-truck"),
                            (TechVisionMaroc.Models.StatutCommande.Livree,        "Livrée",          "fa-box-open"),
                        };
                        bool annulee = Model.Statut == TechVisionMaroc.Models.StatutCommande.Annulee
                                    || Model.Statut == TechVisionMaroc.Models.StatutCommande.Remboursee;
                        int statutIndex = Array.IndexOf(etapes.Select(e => e.Item1).ToArray(), Model.Statut);
                    }
                    @if (annulee)
                    {
                        <div class="text-danger small">
                            <i class="fas fa-times-circle me-2"></i>
                            Commande @Model.Statut.ToString().ToLower()
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var (statut, label, ico) in etapes)
                            {
                                int idx = Array.IndexOf(etapes.Select(e => e.Item1).ToArray(), statut);
                                bool fait = idx <= statutIndex;
                                bool actuel = idx == statutIndex;
                                <div class="d-flex align-items-center gap-2 small @(fait ? "text-success fw-semibold" : "text-muted")">
                                    <i class="fas @ico @(actuel ? "fa-beat" : "")"></i>
                                    @label
                                    @if (actuel)
                                    {
                                        <span class="badge bg-success ms-auto">En cours</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <a href="/Account/Profil" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour à mes commandes
        </a>
        <a href="/Commande/Facture/@Model.Id" class="btn btn-danger ms-2" target="_blank">
            <i class="fas fa-file-pdf me-2"></i>Télécharger ma facture PDF
        </a>
        <a href="/Catalogue" class="btn btn-primary ms-2">
            <i class="fas fa-shopping-bag me-2"></i>Continuer mes achats
        </a>
    </div>
</div>
