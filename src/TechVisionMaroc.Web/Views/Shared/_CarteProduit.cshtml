@model TechVisionMaroc.Models.Produit
@inject IPrixService Prix

<div class="card h-100 border-0 shadow-sm hover-lift product-card">
    <div class="position-relative">
        <a href="/Produit/Details/@Model.Id">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder.svg" : Model.ImageUrl)"
                 class="card-img-top product-img" alt="@Model.Nom" />
        </a>
        <!-- Bouton wishlist (cœur) -->
        <button type="button" class="btn btn-light btn-sm wishlist-btn position-absolute top-0 end-0 m-2 rounded-circle shadow-sm"
                data-produit-id="@Model.Id" title="Ajouter à ma liste de souhaits"
                style="width:38px;height:38px;padding:0;">
            <i class="far fa-heart text-danger"></i>
        </button>
        @if (Model.PrixPromo.HasValue)
        {
            var remise = (int)Math.Round((1 - Model.PrixPromo.Value / Model.Prix) * 100);
            <span class="badge bg-danger position-absolute top-0 start-0 m-2">-@remise%</span>
        }
        @if (Model.EstVedette)
        {
            <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">
                <i class="fas fa-star me-1"></i>Vedette
            </span>
        }
        @if (Model.Stock == 0)
        {
            <div class="position-absolute bottom-0 start-0 end-0 bg-dark bg-opacity-75 text-white text-center py-1 small">
                Rupture de stock
            </div>
        }
    </div>
    <div class="card-body d-flex flex-column p-3">
        <div class="text-muted small mb-1">@Model.Marque</div>
        <h6 class="card-title fw-semibold mb-2 product-title">
            <a href="/Produit/Details/@Model.Id" class="text-dark text-decoration-none">@Model.Nom</a>
        </h6>

        @if (Model.NoteMoyenne > 0)
        {
            <div class="mb-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fas fa-star @(i <= Model.NoteMoyenne ? "text-warning" : "text-muted")" style="font-size:.7rem"></i>
                }
                <small class="text-muted ms-1">(@Model.NombreAvis)</small>
            </div>
        }

        <div class="mt-auto">
            <div class="d-flex align-items-center gap-2 mb-2">
                @if (Model.PrixPromo.HasValue)
                {
                    <span class="fw-bold text-primary fs-5">@Prix.Format(Model.PrixPromo.Value, Model.TauxTVA)</span>
                    <span class="text-muted text-decoration-line-through small">@Prix.Format(Model.Prix, Model.TauxTVA, false)</span>
                }
                else
                {
                    <span class="fw-bold text-primary fs-5">@Prix.Format(Model.Prix, Model.TauxTVA)</span>
                }
            </div>

            @if (Model.Stock > 0)
            {
                <form asp-controller="Panier" asp-action="Ajouter" method="post">
                    <input type="hidden" name="produitId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="fas fa-cart-plus me-1"></i>Ajouter au panier
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary btn-sm w-100" disabled>Indisponible</button>
            }

        </div>
    </div>
</div>
