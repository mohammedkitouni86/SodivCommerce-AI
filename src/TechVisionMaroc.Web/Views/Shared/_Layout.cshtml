<!-- Tracking comportemental automatique -->
<script>
(function () {
    const TRACK_URL = '/track';
    function send(payload, beacon) {
        try {
            const body = JSON.stringify(payload);
            if (beacon && navigator.sendBeacon) {
                navigator.sendBeacon(TRACK_URL, new Blob([body], { type: 'application/json' }));
            } else {
                fetch(TRACK_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: body,
                    keepalive: true
                }).catch(() => {});
            }
        } catch (e) {}
    }

    // Page vue
    send({ Type: 'PageVue', Etiquette: document.title });

    // Profondeur de scroll : 25/50/75/100
    const seuils = [25, 50, 75, 100];
    const atteints = new Set();
    function onScroll() {
        const h = document.documentElement;
        const total = (h.scrollHeight - h.clientHeight) || 1;
        const pct = Math.round((h.scrollTop || window.scrollY) / total * 100);
        seuils.forEach(s => {
            if (pct >= s && !atteints.has(s)) {
                atteints.add(s);
                send({ Type: 'ScrollProfondeur', Valeur: s });
            }
        });
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // Durée page
    const debut = Date.now();
    let envoyeDuree = false;
    function envoyerDuree() {
        if (envoyeDuree) return;
        envoyeDuree = true;
        send({ Type: 'DureePage', DureeMs: Date.now() - debut }, true);
    }
    window.addEventListener('pagehide', envoyerDuree);
    document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'hidden') envoyerDuree();
    });

    // Recherche
    document.addEventListener('submit', function (e) {
        const f = e.target;
        if (f && f.matches && f.matches('form[action*="/recherche"], form#formRecherche, form.form-recherche')) {
            const q = f.querySelector('input[name="q"], input[type="search"]');
            send({ Type: 'RechercheSubmit', Etiquette: q ? q.value : null });
        }
    }, true);

    // Clics sur catégories
    document.addEventListener('click', function (e) {
        const a = e.target.closest && e.target.closest('a[data-categorie-id], .clic-categorie');
        if (a) {
            const id = parseInt(a.getAttribute('data-categorie-id') || '0', 10);
            send({ Type: 'ClicCategorie', CibleType: 'Categorie', CibleId: id || null, Etiquette: a.textContent?.trim()?.slice(0, 100) });
        }
    }, true);
})();
</script>

