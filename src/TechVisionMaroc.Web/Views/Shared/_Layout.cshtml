<script>
(function () {
    const estConnecte = @(estConnecte ? "true" : "false");
    const tokenField  = document.querySelector('#wishlistAfForm input[name]');
    const tokenName   = tokenField?.name;
    const tokenValue  = tokenField?.value;

    document.addEventListener('click', async function (ev) {
        const btn = ev.target.closest('.wishlist-btn');
        if (!btn) return;
        ev.preventDefault();

        if (!estConnecte) {
            if (confirm("Connectez-vous pour ajouter ce produit à votre liste de souhaits.\nAller à la page de connexion ?"))
                window.location.href = '/Account/Connexion?retour=' + encodeURIComponent(window.location.pathname);
            return;
        }

        const id = btn.getAttribute('data-produit-id');
        if (!id) return;

        const icon = btn.querySelector('i');
        btn.disabled = true;
        const ancien = icon ? icon.className : '';
        if (icon) icon.className = 'fas fa-spinner fa-spin';

        try {
            const fd = new FormData();
            fd.append('produitId', id);
            if (tokenName && tokenValue) fd.append(tokenName, tokenValue);

            const res = await fetch('/wishlist/basculer', {
                method: 'POST',
                headers: { 'X-Requested-With': 'fetch' },
                body: fd
            });
            const data = await res.json();
            if (!data.ok) { if (icon) icon.className = ancien; btn.disabled = false; return; }

            // Maj du cœur
            if (icon) {
                icon.className = data.ajoute ? 'fas fa-heart text-danger' : 'far fa-heart text-danger';
            }
            btn.classList.toggle('actif', data.ajoute);

            // Maj du badge global
            const badge = document.getElementById('wishlistCountBadge');
            if (badge) {
                if (data.total > 0) { badge.textContent = data.total; badge.classList.remove('d-none'); }
                else                { badge.classList.add('d-none'); }
            }
        } catch (e) {
            if (icon) icon.className = ancien;
        } finally {
            btn.disabled = false;
        }
    });
})();
</script>

