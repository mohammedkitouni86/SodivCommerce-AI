@{
    ViewData["Title"] = "Contact";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <h1 class="fw-bold"><i class="fas fa-envelope-open-text text-primary me-2"></i>Contactez-nous</h1>
                <p class="text-muted">Une question ? Un devis ? Notre équipe vous répond sous 24 h.</p>
            </div>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row g-4">
                <!-- Coordonnées -->
                <div class="col-md-5">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Nos coordonnées</h5>

                            <div class="d-flex mb-3">
                                <div class="me-3 text-primary"><i class="fas fa-map-marker-alt fa-lg"></i></div>
                                <div>
                                    <div class="fw-semibold">Adresse</div>
                                    <div class="text-muted small">Salé, Maroc</div>
                                </div>
                            </div>

                            <div class="d-flex mb-3">
                                <div class="me-3 text-primary"><i class="fas fa-phone fa-lg"></i></div>
                                <div>
                                    <div class="fw-semibold">Téléphone</div>
                                    <a href="tel:+212661900569" class="text-muted small text-decoration-none">+212 661 900 569</a>
                                </div>
                            </div>

                            <div class="d-flex mb-3">
                                <div class="me-3 text-primary"><i class="fas fa-envelope fa-lg"></i></div>
                                <div>
                                    <div class="fw-semibold">Email</div>
                                    <a href="mailto:sodivbureau@gmail.com" class="text-muted small text-decoration-none">sodivbureau@gmail.com</a>
                                </div>
                            </div>

                            <div class="d-flex mb-3">
                                <div class="me-3 text-primary"><i class="fab fa-whatsapp fa-lg"></i></div>
                                <div>
                                    <div class="fw-semibold">WhatsApp</div>
                                    <a href="https://wa.me/212661900569" target="_blank" class="text-muted small text-decoration-none">+212 661 900 569</a>
                                </div>
                            </div>

                            <div class="d-flex">
                                <div class="me-3 text-primary"><i class="fas fa-clock fa-lg"></i></div>
                                <div>
                                    <div class="fw-semibold">Horaires</div>
                                    <div class="text-muted small">Lundi – Samedi : 9h – 18h</div>
                                </div>
                            </div>

                            <hr class="my-4" />
                            <div class="d-flex gap-3 justify-content-center">
                                <a href="#" class="text-primary"><i class="fab fa-facebook fa-2x"></i></a>
                                <a href="#" class="text-primary"><i class="fab fa-instagram fa-2x"></i></a>
                                <a href="#" class="text-primary"><i class="fab fa-linkedin fa-2x"></i></a>
                                <a href="https://wa.me/212661900569" target="_blank" class="text-primary"><i class="fab fa-whatsapp fa-2x"></i></a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Formulaire -->
                <div class="col-md-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Envoyez-nous un message</h5>
                            <form method="post" action="/Home/Contact">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label for="nom" class="form-label">Nom complet <span class="text-danger">*</span></label>
                                    <input type="text" id="nom" name="nom" class="form-control" required maxlength="100" />
                                </div>
                                <div class="mb-3">
                                    <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                                    <input type="email" id="email" name="email" class="form-control" required maxlength="150" />
                                </div>
                                <div class="mb-3">
                                    <label for="message" class="form-label">Message <span class="text-danger">*</span></label>
                                    <textarea id="message" name="message" class="form-control" rows="6" required maxlength="2000"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-paper-plane me-2"></i>Envoyer le message
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Carte -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-0" style="overflow:hidden; border-radius:.5rem;">
                    <iframe src="https://maps.google.com/maps?q=Sal%C3%A9%2C%20Maroc&t=&z=13&ie=UTF8&iwloc=&output=embed"
                            style="border:0; width:100%; height:380px;" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Localisation Sodiv Bureau — Salé"></iframe>
                </div>
                <div class="card-footer bg-white text-center">
                    <a href="https://www.google.com/maps/search/?api=1&query=Sal%C3%A9%2C+Maroc" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-external-link-alt me-1"></i>Ouvrir dans Google Maps
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
