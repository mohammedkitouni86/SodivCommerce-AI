@{
    ViewData["Title"] = "Vérification 2FA";
}
<div class="container py-5" style="max-width:480px">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 text-center">
            <i class="fas fa-shield-halved fa-3x text-success mb-3"></i>
            <h2 class="h4 fw-bold mb-2">Vérification en 2 étapes</h2>
            <p class="text-muted">Entrez le code à 6 chiffres de votre application Authenticator.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input name="code" type="text" maxlength="6" pattern="\d{6}" required autofocus
                       class="form-control form-control-lg text-center"
                       style="letter-spacing:8px;font-size:2rem"
                       placeholder="000000" autocomplete="one-time-code" />
                <button type="submit" class="btn btn-success btn-lg w-100 mt-3">
                    <i class="fas fa-check me-1"></i>Vérifier
                </button>
            </form>
            <a href="/Account/Connexion" class="d-block mt-3 small text-muted">← Annuler</a>
        </div>
    </div>
</div>
