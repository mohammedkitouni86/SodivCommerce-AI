@{
    ViewData["Title"] = "Code PIN";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Accès sécurisé — SODIV Bureau</title>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/lib/fontawesome/css/all.min.css" rel="stylesheet" />
</head>
<body class="bg-dark d-flex align-items-center justify-content-center min-vh-100">

<div class="card border-0 shadow-lg" style="width:380px">
    <div class="card-header text-white text-center py-4" style="background:#1a1a2e">
        <i class="fas fa-shield-alt fa-3x text-warning mb-3 d-block"></i>
        <h5 class="fw-bold mb-1">Panneau Administrateur</h5>
        <small class="text-muted">Entrez votre code PIN pour continuer</small>
    </div>

    <div class="card-body p-4">

        @if (ViewBag.Erreur != null)
        {
            <div class="alert alert-danger text-center py-2">
                <i class="fas fa-times-circle me-2"></i>@ViewBag.Erreur
            </div>
        }

        <form method="post" action="@ViewBag.PinActionUrl">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-4">
                <label class="form-label text-center d-block fw-semibold mb-3">Code PIN</label>

                <!-- Affichage des 4 cases -->
                <div class="d-flex justify-content-center gap-3 mb-3" id="casesPin">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="border-bottom border-3 border-warning text-center fw-bold fs-3 text-white"
                             style="width:50px;min-height:45px;background:transparent" id="case@(i)"></div>
                    }
                </div>

                <!-- Input caché -->
                <input type="password"
                       name="code"
                       id="pinInput"
                       maxlength="10"
                       autocomplete="off"
                       class="form-control opacity-0 position-absolute"
                       style="pointer-events:none;top:-9999px" />
            </div>

            <!-- Clavier numérique -->
            <div class="row g-2 mb-3">
                @foreach (var n in new[] { "1","2","3","4","5","6","7","8","9","","0","⌫" })
                {
                    if (string.IsNullOrEmpty(n))
                    {
                        <div class="col-4"></div>
                    }
                    else
                    {
                        <div class="col-4">
                            <button type="button"
                                    class="btn w-100 py-3 fw-bold fs-5 @(n == "⌫" ? "btn-outline-danger" : "btn-outline-light")"
                                    onclick="@(n == "⌫" ? "saisirPin('back')" : $"saisirPin('{n}')")">
                                @n
                            </button>
                        </div>
                    }
                }
            </div>

            <button type="submit" id="btnValider" class="btn btn-warning w-100 btn-lg fw-bold d-none">
                <i class="fas fa-unlock me-2"></i>Déverrouiller
            </button>
        </form>

        <div class="text-center mt-3">
            <a href="/" class="text-secondary small text-decoration-none">
                <i class="fas fa-home me-1"></i>Retour au site
            </a>
        </div>
    </div>
</div>

<script>
var code = '';
var maxLen = 4;

function saisirPin(val) {
    if (val === 'back') {
        code = code.slice(0, -1);
    } else if (code.length < maxLen) {
        code += val;
    }
    afficher();
    if (code.length === maxLen) {
        document.getElementById('pinInput').value = code;
        document.getElementById('btnValider').classList.remove('d-none');
        // Auto-soumettre après un court délai pour meilleure UX
        setTimeout(() => document.querySelector('form').submit(), 300);
    } else {
        document.getElementById('pinInput').value = '';
        document.getElementById('btnValider').classList.add('d-none');
    }
}

function afficher() {
    for (var i = 0; i < maxLen; i++) {
        var el = document.getElementById('case' + i);
        if (i < code.length) {
            el.textContent = '●';
            el.classList.add('border-warning');
        } else {
            el.textContent = '';
            el.classList.remove('border-warning');
        }
    }
}

// Saisie clavier physique aussi
document.addEventListener('keydown', function(e) {
    if (e.key >= '0' && e.key <= '9') saisirPin(e.key);
    else if (e.key === 'Backspace') saisirPin('back');
    else if (e.key === 'Enter' && code.length === maxLen) document.querySelector('form').submit();
});
</script>
</body>
</html>
