@{ ViewData["Title"] = "À propos de SODIV Bureau"; }

<!-- Hero -->
<section class="bg-gradient-primary text-white py-5">
    <div class="container py-4 text-center">
        <h1 class="display-4 fw-bold">À propos de SODIV Bureau</h1>
        <p class="lead opacity-90 mb-0">Votre partenaire de confiance pour l'équipement professionnel au Maroc</p>
    </div>
</section>

<div class="container py-5">

    <!-- Histoire -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <h2 class="fw-bold text-primary mb-3">Notre histoire</h2>
            <p class="lead">Depuis sa création, <strong>SODIV Bureau</strong> s'est imposé comme une référence dans la fourniture de matériel informatique et de mobilier de bureau au Maroc.</p>
            <p>Basée à <strong>Salé</strong>, notre entreprise accompagne les administrations publiques, entreprises privées, écoles et professionnels indépendants dans l'aménagement de leurs espaces de travail. Notre showroom, ouvert du lundi au samedi, vous permet de tester nos produits avant achat.</p>
            <p>Nous croyons qu'un environnement de travail bien équipé est la clé de la productivité et du bien-être. C'est pourquoi nous sélectionnons rigoureusement nos fournisseurs et offrons un service après-vente irréprochable.</p>
        </div>
        <div class="col-lg-5 text-center">
            <i class="fas fa-building text-primary" style="font-size:10rem; opacity:.15;"></i>
        </div>
    </div>

    <!-- Valeurs -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Nos valeurs</h2>
        <p class="text-muted">Ce qui guide notre action au quotidien</p>
    </div>
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-handshake fa-3x text-primary mb-3"></i>
                    <h5 class="fw-bold">Confiance</h5>
                    <p class="small text-muted mb-0">Des relations durables avec nos clients et partenaires</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-medal fa-3x text-warning mb-3"></i>
                    <h5 class="fw-bold">Qualité</h5>
                    <p class="small text-muted mb-0">Des produits sélectionnés auprès des meilleures marques</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-bolt fa-3x text-info mb-3"></i>
                    <h5 class="fw-bold">Réactivité</h5>
                    <p class="small text-muted mb-0">Livraison rapide et réponse sous 24h aux demandes</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center">
                <div class="card-body p-4">
                    <i class="fas fa-headset fa-3x text-success mb-3"></i>
                    <h5 class="fw-bold">Proximité</h5>
                    <p class="small text-muted mb-0">Une équipe à votre écoute, en français, arabe et anglais</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Chiffres -->
    <div class="bg-light rounded-4 p-5 mb-5">
        <div class="row text-center">
            <div class="col-md-3 mb-3">
                <div class="display-4 fw-bold text-primary">500+</div>
                <small class="text-muted">Clients satisfaits</small>
            </div>
            <div class="col-md-3 mb-3">
                <div class="display-4 fw-bold text-primary">1000+</div>
                <small class="text-muted">Commandes livrées</small>
            </div>
            <div class="col-md-3 mb-3">
                <div class="display-4 fw-bold text-primary">5</div>
                <small class="text-muted">Années d'expérience</small>
            </div>
            <div class="col-md-3 mb-3">
                <div class="display-4 fw-bold text-primary">98%</div>
                <small class="text-muted">Taux de satisfaction</small>
            </div>
        </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
        <h3 class="fw-bold mb-3">Prêt à équiper votre espace ?</h3>
        <p class="text-muted mb-4">Découvrez notre catalogue ou contactez-nous pour un devis personnalisé</p>
        <a href="/Catalogue" class="btn btn-primary btn-lg me-2"><i class="fas fa-shopping-bag me-2"></i>Voir le catalogue</a>
        <a href="https://wa.me/212661900569" class="btn btn-success btn-lg"><i class="fab fa-whatsapp me-2"></i>Nous contacter</a>
    </div>
</div>
