<!-- Recherche par image (similarité visuelle) -->
<script>
(function () {
    const btnImage   = document.getElementById('btnRechercheImage');
    const fileImage  = document.getElementById('fileRechercheImage');
    const input      = document.getElementById('searchInput');
    const form       = document.getElementById('formRecherche');
    const btnMicro   = document.getElementById('btnMicroBarre');

    // ── Recherche vocale (Web Speech API navigateur) ──
    if (btnMicro && input && form) {
        const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SR) {
            btnMicro.style.display = 'none';
        } else {
            const reco = new SR();
            reco.lang = (document.documentElement.lang || 'fr-FR');
            if (reco.lang === 'fr') reco.lang = 'fr-FR';
            if (reco.lang === 'ar') reco.lang = 'ar-MA';
            reco.continuous = false;
            reco.interimResults = false;
            let listening = false;
            btnMicro.addEventListener('click', () => {
                if (listening) { try { reco.stop(); } catch {} return; }
                try { reco.start(); } catch {}
            });
            reco.onstart  = () => { listening = true;  btnMicro.classList.add('recording'); };
            reco.onend    = () => { listening = false; btnMicro.classList.remove('recording'); };
            reco.onerror  = () => { listening = false; btnMicro.classList.remove('recording'); };
            reco.onresult = (e) => {
                const txt = e.results?.[0]?.[0]?.transcript || '';
                if (!txt) return;
                input.value = txt;
                form.submit();
            };
        }
    }

    // ── Recherche par image (similarité visuelle) ──
    if (btnImage && fileImage) {
        btnImage.addEventListener('click', () => fileImage.click());
        fileImage.addEventListener('change', async () => {
            const f = fileImage.files?.[0];
            if (!f) return;
            const fd = new FormData();
            fd.append('image', f);
            btnImage.disabled = true;
            const oldIcon = btnImage.innerHTML;
            btnImage.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            try {
                const res = await fetch('/Catalogue/RechercheImage', { method: 'POST', body: fd });
                const data = await res.json().catch(() => null);
                if (data?.redirect)   { window.location = data.redirect; return; }
                if (data?.q)          { window.location = '/recherche?q=' + encodeURIComponent(data.q); return; }
                alert(data?.erreur || "Aucun produit similaire trouvé.");
            } catch (e) {
                alert("Erreur lors de l'analyse de l'image.");
            } finally {
                btnImage.disabled = false;
                btnImage.innerHTML = oldIcon;
                fileImage.value = '';
            }
        });
    }
})();
</script>

<!-- Chatbot SODIVA -->
<script>
(function () {
    const toggle  = document.getElementById('chatbotToggle');
    const panel   = document.getElementById('chatbotPanel');
    const closeBt = document.getElementById('chatbotClose');
    const resetBt = document.getElementById('chatbotReset');
    const form    = document.getElementById('chatbotForm');
    const input   = document.getElementById('chatbotInput');
    const msgs    = document.getElementById('chatbotMessages');
    const sendBt  = document.getElementById('chatbotSend');
    const attachBt= document.getElementById('chatbotAttach');
    const fileInp = document.getElementById('chatbotFile');

    function ouvrir()  { panel.classList.remove('d-none'); toggle.classList.add('actif'); setTimeout(() => input.focus(), 200); activiteUtilisateur(); }
    function fermer()  { panel.classList.add('d-none');    toggle.classList.remove('actif'); clearTimeout(idleTimer); }
    toggle.addEventListener('click', () => panel.classList.contains('d-none') ? ouvrir() : fermer());
    closeBt.addEventListener('click', fermer);

    const STORAGE_KEY = 'sodiva_chat_hist';
    // Visiteur (non connecté) → sessionStorage : l'historique est effacé à la fermeture
    // de l'onglet (pas conservé durablement). Client connecté → localStorage (persistant,
    // effacé à la déconnexion). On détecte la connexion via la présence du lien Déconnexion.
    const estConnecte = !!document.querySelector('a[href^="/Account/Deconnexion"]');
    const store = estConnecte ? window.localStorage : window.sessionStorage;
    // Nettoyage : un visiteur ne doit pas hériter d'un historique persistant.
    if (!estConnecte) { try { localStorage.removeItem(STORAGE_KEY); } catch {} }

    function chargerHistorique() {
        try { return JSON.parse(store.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
    }
    function sauverHistorique(hist) {
        try { store.setItem(STORAGE_KEY, JSON.stringify(hist.slice(-20))); } catch {}
    }

    function rendre(role, html, produits) {
        const div = document.createElement('div');
        div.className = 'chatbot-msg ' + (role === 'user' ? 'user' : 'bot');
        div.innerHTML = html;
        msgs.appendChild(div);
        if (produits && produits.length) {
            const grid = document.createElement('div');
            grid.className = 'chatbot-produits';
            produits.slice(0, 4).forEach(p => {
                const card = document.createElement('a');
                card.href = p.url; card.className = 'chatbot-produit';
                card.innerHTML = `<img src="${p.imageUrl}" alt=""><div><div class="nom">${p.nom}</div><div class="prix">${Math.round(p.prix).toLocaleString()} MAD</div></div>`;
                grid.appendChild(card);
            });
            msgs.appendChild(grid);
        }
        msgs.scrollTop = msgs.scrollHeight;
    }

    function ajouter(role, html, produits) {
        rendre(role, html, produits);
        const hist = chargerHistorique();
        hist.push({ role, html, produits: produits || null });
        sauverHistorique(hist);
    }

    // Si la page est rechargée (F5), on efface l'historique. Sinon (navigation), on le restaure.
    const navType = performance.getEntriesByType('navigation')[0]?.type;
    if (navType === 'reload') {
        store.removeItem(STORAGE_KEY);
        fetch('/api/chatbot/reset', { method: 'POST' }).catch(() => {});
    } else {
        const histInit = chargerHistorique();
        if (histInit.length) {
            msgs.innerHTML = '';
            histInit.forEach(m => rendre(m.role, m.html, m.produits));
        }
    }

    function ajouterTyping() {
        const t = document.createElement('div');
        t.className = 'chatbot-msg bot typing';
        t.id = 'chatbotTyping';
        t.innerHTML = '<span></span><span></span><span></span>';
        msgs.appendChild(t);
        msgs.scrollTop = msgs.scrollHeight;
    }
    function retirerTyping() { document.getElementById('chatbotTyping')?.remove(); }

    function echappe(s) { return s.replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c])); }

    async function envoyerTexte(txt) {
        if (!txt) return;
        activiteUtilisateur();
        ajouter('user', echappe(txt));
        input.value = '';
        sendBt.disabled = true;
        ajouterTyping();
        try {
            const res = await fetch('/api/chatbot/message', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: txt })
            });
            const data = await res.json();
            retirerTyping();
            if (data.reponse) ajouter('bot', echappe(data.reponse).replace(/\n/g, '<br>'), data.produits);
            else ajouter('bot', data.erreur || 'Désolée, une erreur est survenue.');
        } catch (err) {
            retirerTyping();
            ajouter('bot', 'Connexion impossible. Réessayez plus tard.');
        } finally {
            sendBt.disabled = false; input.focus();
        }
    }

    // ── Relance proactive après 30 s d'inactivité (chat ouvert) ──
    let idleTimer = null, relances = 0;
    const DELAI_INACTIVITE = 20000; // 20 secondes
    const MAX_RELANCES = 2;
    const MSG_RELANCE = [
        "🎁 Saviez-vous que la livraison est <strong>GRATUITE dès 1 000 MAD</strong> ? Dites-moi ce que vous cherchez, je vous trouve les meilleures offres !",
        "⏳ Nos promotions changent vite ! Découvrez nos <a href='/Home/Promotions' style='color:#0d6efd;font-weight:700;text-decoration:underline'>réductions du moment</a> 🏷️."
    ];
    function programmerRelance() {
        clearTimeout(idleTimer);
        if (panel.classList.contains('d-none')) return;   // chat fermé
        if (relances >= MAX_RELANCES) return;             // assez relancé
        idleTimer = setTimeout(() => {
            ajouter('bot', MSG_RELANCE[relances]);
            relances++;
            programmerRelance();                           // planifier la suivante
        }, DELAI_INACTIVITE);
    }
    function activiteUtilisateur() { relances = 0; programmerRelance(); }
    input.addEventListener('input', activiteUtilisateur);

    form.addEventListener('submit', (e) => { e.preventDefault(); envoyerTexte(input.value.trim()); });

    // ── Boutons rapides de la carte d'accueil ──
    msgs.addEventListener('click', (e) => {
        const b = e.target.closest('.cw-btn'); if (!b) return;
        activiteUtilisateur();
        const qr = b.dataset.qr;
        if (qr === 'photo')       fileInp.click();
        else if (qr === 'promos') {
            ajouter('bot', "🏷️ Voici toutes nos <strong>promotions du moment</strong> ! Je vous y emmène…");
            setTimeout(() => { window.location.href = '/Home/Promotions'; }, 900);
        }
        else { input.focus(); input.placeholder = 'Décrivez le produit recherché…'; }
    });

    // ── Envoi de PHOTO pour trouver des produits ──
    function rendreImage(src) {
        const div = document.createElement('div');
        div.className = 'chatbot-msg user has-img';
        div.innerHTML = `<img src="${src}" class="chatbot-img-up" alt="photo">`;
        msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
    }
    attachBt.addEventListener('click', () => fileInp.click());
    fileInp.addEventListener('change', async () => {
        const f = fileInp.files && fileInp.files[0];
        if (!f) return;
        activiteUtilisateur();
        if (!f.type.startsWith('image/')) { ajouter('bot', 'Veuillez envoyer une image (JPG, PNG…).'); fileInp.value=''; return; }
        if (f.size > 8 * 1024 * 1024)     { ajouter('bot', 'Image trop volumineuse (max 8 Mo).'); fileInp.value=''; return; }
        rendreImage(URL.createObjectURL(f));
        ajouterTyping();
        try {
            const fd = new FormData(); fd.append('image', f);
            const res = await fetch('/api/chatbot/image', { method: 'POST', body: fd });
            const data = await res.json();
            retirerTyping();
            ajouter('bot', echappe(data.reponse || '').replace(/\n/g, '<br>'), data.produits);
        } catch (err) {
            retirerTyping();
            ajouter('bot', "Je n'ai pas pu analyser l'image. Réessayez.");
        } finally {
            fileInp.value = '';
        }
    });

    resetBt.addEventListener('click', async () => {
        await fetch('/api/chatbot/reset', { method: 'POST' });
        store.removeItem(STORAGE_KEY);
        msgs.innerHTML = '<div class="chatbot-msg bot">Nouvelle conversation. Comment puis-je vous aider ?</div>';
    });

    // À la déconnexion : effacer l'historique du chatbot (côté navigateur).
    document.querySelectorAll('a[href^="/Account/Deconnexion"]').forEach(a =>
        a.addEventListener('click', () => { try { localStorage.removeItem(STORAGE_KEY); } catch {} }));
})();
</script>

