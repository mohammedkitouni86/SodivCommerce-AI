@{
    ViewData["Title"] = "Changer le code PIN";
}

<div class="bg-dark text-white py-3 border-bottom">
    <div class="container-fluid px-4">
        <div class="d-flex align-items-center gap-3">
            <a href="@ViewBag.AdminBase" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h4 class="mb-0 fw-bold">
                <i class="fas fa-key me-2 text-warning"></i>Changer le code PIN
            </h4>
        </div>
    </div>
</div>

<div class="container py-5" style="max-width:480px">

    <div class="card border-0 shadow-sm border-warning" style="border-left:4px solid #ffc107!important">
        <div class="card-header bg-warning bg-opacity-10 border-0 fw-semibold">
            <i class="fas fa-shield-alt text-warning me-2"></i>Modification du code PIN d'accès admin
        </div>
        <div class="card-body">
            <p class="text-muted small mb-4">
                Le code PIN protège l'accès à l'interface d'administration.
                Après modification, vous devrez saisir le nouveau PIN.
            </p>

            <form method="post" action="@ViewBag.AdminBase/parametres/pin">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">PIN actuel <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="password" name="pinActuel" id="pinActuel" class="form-control"
                               placeholder="••••" maxlength="8" inputmode="numeric"
                               pattern="[0-9]*" autocomplete="current-password" required />
                        <button type="button" class="btn btn-outline-secondary" onclick="toggleVis('pinActuel','eye1')">
                            <i class="fas fa-eye" id="eye1"></i>
                        </button>
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Nouveau PIN <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="password" name="nouveauPin" id="nouveauPin" class="form-control"
                               placeholder="Minimum 4 chiffres" maxlength="8" inputmode="numeric"
                               pattern="[0-9]{4,8}" autocomplete="new-password" required />
                        <button type="button" class="btn btn-outline-secondary" onclick="toggleVis('nouveauPin','eye2')">
                            <i class="fas fa-eye" id="eye2"></i>
                        </button>
                    </div>
                    <div class="form-text">4 à 8 chiffres uniquement.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Confirmer le nouveau PIN <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="password" name="confirmerPin" id="confirmerPin" class="form-control"
                               placeholder="Répétez le nouveau PIN" maxlength="8" inputmode="numeric"
                               pattern="[0-9]{4,8}" autocomplete="new-password" required />
                        <button type="button" class="btn btn-outline-secondary" onclick="toggleVis('confirmerPin','eye3')">
                            <i class="fas fa-eye" id="eye3"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="fas fa-save me-2"></i>Enregistrer le nouveau PIN
                    </button>
                    <a href="@ViewBag.AdminBase" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function toggleVis(inputId, iconId) {
    var input = document.getElementById(inputId);
    var icon  = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
