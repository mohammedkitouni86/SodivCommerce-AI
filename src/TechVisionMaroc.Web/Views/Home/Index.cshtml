<!-- Catégories -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-down">
            <h2 class="fw-bold">@T.Get("NosCategories")</h2>
            <p class="text-muted">@T.Get("CliquezCategorie")</p>
        </div>

        <!-- Grille des catégories parentes -->
        <div class="row g-3 justify-content-center" id="grilleCats">
            @{ int catIdx = 0; }
            @foreach (var cat in categories)
            {
                var hasSous = cat.SousCategories.Any();
                <div class="col-6 col-md-4 col-lg-2" data-aos="zoom-in" data-aos-delay="@(catIdx * 60)">
                    <div class="cat-card card h-100 text-center text-decoration-none border-0 shadow-sm p-3
                                @(hasSous ? "has-sous" : "")"
                         data-cat-id="@cat.Id"
                         style="cursor:pointer;transition:all .2s">
                @{ catIdx++; }
                        <div class="card-body p-2">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center
                                        justify-content-center mb-3"
                                 style="width:56px;height:56px">
                                <i class="fas @cat.IconeClass fa-lg text-primary"></i>
                            </div>
                            <div class="fw-semibold small">@cat.Nom</div>
                            @if (hasSous)
                            {
                                <div class="text-muted mt-1" style="font-size:.7rem">
                                    <i class="fas fa-chevron-down cat-arrow" style="transition:.2s"></i>
                                    @cat.SousCategories.Count sous-catégorie(s)
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Panel sous-catégories (s'affiche sous la grille) -->
        <div id="panelSousCats" class="mt-4 d-none">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">
                            <i class="fas fa-tags text-primary me-2"></i>
                            <span id="panelTitre"></span>
                        </h5>
                        <button class="btn btn-sm btn-outline-secondary" onclick="fermerPanel()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="row g-3" id="listeSousCats"></div>
                    <div class="mt-3 text-center">
                        <a href="#" id="lienTousProduits" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-th me-1"></i>Voir tous les produits de cette catégorie
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Données des sous-catégories (JSON) -->
@{
    var catsJson = System.Text.Json.JsonSerializer.Serialize(
        categories.ToDictionary(
            c => c.Id.ToString(),
            c => new {
                nom      = c.Nom,
                icone    = c.IconeClass,
                lien     = $"/Catalogue?categorieId={c.Id}",
                sousCats = c.SousCategories.Select(s => new { id = s.Id, nom = s.Nom, icone = s.IconeClass }).ToList()
            }
        )
    );
}
<script>
const categoriesData = @Html.Raw(catsJson);

let catActive = null;

document.querySelectorAll('.cat-card').forEach(card => {
    card.addEventListener('click', function () {
        const id  = parseInt(this.dataset.catId);
        const cat = categoriesData[id];
        if (!cat) { window.location = '/Catalogue?categorieId=' + id; return; }

        if (!cat.sousCats.length) { window.location = cat.lien; return; }

        // Désactiver l'ancienne carte active
        document.querySelectorAll('.cat-card').forEach(c => {
            c.classList.remove('border-primary', 'border-2');
            c.querySelector('.cat-arrow')?.classList.remove('fa-chevron-up');
            c.querySelector('.cat-arrow')?.classList.add('fa-chevron-down');
        });

        if (catActive === id) {
            fermerPanel();
            return;
        }

        catActive = id;
        this.classList.add('border-primary', 'border-2');
        this.querySelector('.cat-arrow')?.classList.replace('fa-chevron-down', 'fa-chevron-up');

        // Remplir le panel
        document.getElementById('panelTitre').textContent = cat.nom;
        document.getElementById('lienTousProduits').href   = cat.lien;

        const liste = document.getElementById('listeSousCats');
        liste.innerHTML = cat.sousCats.map(s => `
            <div class="col-6 col-md-3 col-lg-2">
                <a href="/Catalogue?categorieId=${s.id}"
                   class="card border-0 bg-light text-center text-decoration-none p-3 h-100 hover-lift">
                    <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-2"
                         style="width:46px;height:46px;box-shadow:0 2px 6px rgba(0,0,0,.08)">
                        <i class="fas ${s.icone} text-primary"></i>
                    </div>
                    <div class="fw-semibold small">${s.nom}</div>
                </a>
            </div>`).join('');

        document.getElementById('panelSousCats').classList.remove('d-none');

        // Scroll vers le panel
        setTimeout(() => document.getElementById('panelSousCats').scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
    });
});

function fermerPanel() {
    catActive = null;
    document.getElementById('panelSousCats').classList.add('d-none');
    document.querySelectorAll('.cat-card').forEach(c => {
        c.classList.remove('border-primary', 'border-2');
        c.querySelector('.cat-arrow')?.classList.replace('fa-chevron-up', 'fa-chevron-down');
    });
}
</script>

