                            <li><a class="dropdown-item" href="/Compte/adresses"><i class="fas fa-map-marker-alt me-2 text-warning"></i>Mes adresses</a></li>
                            <li><a class="dropdown-item" href="/Compte/coupons"><i class="fas fa-ticket-alt me-2 text-success"></i>Mes coupons</a></li>
                            <li><a class="dropdown-item" href="/Compte/messages"><i class="fas fa-comments me-2 text-primary"></i>Messages</a></li>
                            <li><a class="dropdown-item" href="/Compte/abonnements"><i class="fas fa-redo me-2 text-info"></i>Abonnements</a></li>
                            <li><a class="dropdown-item" href="/Compte/devis"><i class="fas fa-file-invoice me-2 text-warning"></i>Mes devis</a></li>
                            <li><a class="dropdown-item" href="/compte/fidelite"><i class="fas fa-coins me-2 text-warning"></i>Fidélité</a></li>
