@inject Microsoft.Extensions.Configuration.IConfiguration Cfg
@{
    ViewData["Title"] = "Accueil";
    var produits = ViewBag.ProduitsVedettes as List<TechVisionMaroc.Models.Produit> ?? new();
    var tendances = ViewBag.ProduitsTendances as List<TechVisionMaroc.Models.Produit> ?? new();
    var categories = ViewBag.Categories as List<TechVisionMaroc.Models.Categorie> ?? new();
    var recommandations = ViewBag.Recommandations as List<TechVisionMaroc.Models.Produit> ?? new();
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var s = Cfg.GetSection("Societe");
}

@section MetaTags {
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="SODIV Bureau — Matériel informatique & Fournitures de bureau au Maroc" />
    <meta property="og:description" content="Votre partenaire de confiance pour l'équipement professionnel à Salé et partout au Maroc. Livraison rapide, paiement sécurisé, retour 7 jours." />
    <meta property="og:image" content="@baseUrl/images/logo-ag.png" />
    <meta property="og:url" content="@baseUrl/" />
    <meta property="og:locale" content="fr_MA" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Schema.org Organization + LocalBusiness (Google rich results / Knowledge Graph) -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Store",
      "name": "@s["Nom"]",
      "image": "@baseUrl/images/logo-ag.png",
      "logo": "@baseUrl/images/logo-ag.png",
      "url": "@baseUrl/",
      "telephone": "@s["Telephone"]",
      "email": "@s["Email"]",
      "priceRange": "MAD",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "@s["Adresse"]",
        "addressLocality": "@s["Ville"]",
        "postalCode": "@s["CodePostal"]",
        "addressCountry": "MA"
      },
      "geo": { "@@type": "GeoCoordinates", "latitude": 34.0531, "longitude": -6.7985 },
      "openingHoursSpecification": [
        { "@@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
          "opens": "09:00", "closes": "18:00" }
      ],
      "sameAs": [
        "https://wa.me/212661900569"
      ],
      "aggregateRating": {
        "@@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "127"
      }
    }
    </script>
}

<!-- ═════════ HERO STYLE SHOPIFY (full-bleed background) ═════════ -->
