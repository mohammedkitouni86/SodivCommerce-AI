@model TechVisionMaroc.Models.Devis
@using TechVisionMaroc.Models
@{
    ViewData["Title"] = "Devis " + Model.NumeroDevis;

    string LibelleStatut(StatutDevis s) => s switch {
        StatutDevis.EnAttente => "En attente de réponse de notre équipe",
        StatutDevis.Repondu   => "Devis reçu — à valider",
        StatutDevis.Accepte   => "Devis accepté",
        StatutDevis.Refuse    => "Devis refusé",
        StatutDevis.Expire    => "Devis expiré",
        _ => s.ToString()
    };
    string CouleurStatut(StatutDevis s) => s switch {
        StatutDevis.EnAttente => "warning",
        StatutDevis.Repondu   => "primary",
        StatutDevis.Accepte   => "success",
        StatutDevis.Refuse    => "danger",
        StatutDevis.Expire    => "secondary",
        _ => "dark"
    };
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Compte" class="text-decoration-none">Mon compte</a></li>
            <li class="breadcrumb-item"><a href="/Compte/devis" class="text-decoration-none">Mes devis</a></li>
            <li class="breadcrumb-item active">@Model.NumeroDevis</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0"><i class="fas fa-file-invoice me-2"></i>Devis @Model.NumeroDevis</h5>
                        <small class="opacity-75">Créé le @Model.DateCreation.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <span class="badge bg-light text-dark fs-6">@LibelleStatut(Model.Statut)</span>
                </div>
                <div class="card-body p-4">

                    <!-- Votre demande -->
                    <h6 class="fw-bold text-muted text-uppercase small">Votre demande</h6>
                    <div class="bg-light p-3 rounded mb-4">
                        @Model.DemandeClient
                    </div>

                    <!-- Lignes -->
                    @if (Model.Lignes.Any())
                    {
                        <h6 class="fw-bold text-muted text-uppercase small">Détail</h6>
                        <div class="table-responsive mb-4">
                            <table class="table">
                                <thead class="table-light">
                                    <tr><th>Description</th><th class="text-center">Qté</th><th class="text-end">PU</th><th class="text-end">Total</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in Model.Lignes)
                                    {
                                        <tr>
                                            <td>
                                                @if (l.Produit != null)
                                                {
                                                    <a href="/Produit/Details/@l.Produit.Id">@l.Produit.Nom</a>
                                                }
                                                <div class="text-muted small">@l.Description</div>
                                            </td>
                                            <td class="text-center">@l.Quantite</td>
                                            <td class="text-end">@(l.PrixUnitaire?.ToString("N0") ?? "—") MAD</td>
                                            <td class="text-end fw-bold">@((l.PrixUnitaire * l.Quantite)?.ToString("N0") ?? "—") MAD</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Réponse admin -->
                    @if (Model.Statut == StatutDevis.Repondu || Model.Statut == StatutDevis.Accepte || Model.Statut == StatutDevis.Refuse)
                    {
                        <div class="alert alert-info">
                            <h6 class="fw-bold mb-2"><i class="fas fa-reply me-2"></i>Réponse de notre équipe</h6>
                            <div style="white-space:pre-wrap">@(Model.ReponseAdmin ?? "—")</div>
                            @if (Model.DateReponse.HasValue)
                            {
                                <small class="text-muted d-block mt-2">Reçue le @Model.DateReponse.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            }
                        </div>
                    }

                    @if (Model.Statut == StatutDevis.Repondu)
                    {
                        <div class="d-flex gap-2 mt-4">
                            <form method="post" action="/Compte/devis/@Model.Id/accepter" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-lg w-100">
                                    <i class="fas fa-check me-2"></i>Accepter ce devis
                                </button>
                            </form>
                            <form method="post" action="/Compte/devis/@Model.Id/refuser" class="flex-grow-1"
                                  onsubmit="return confirm('Refuser ce devis ?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-lg w-100">
                                    <i class="fas fa-times me-2"></i>Refuser
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold text-muted text-uppercase small mb-3">Récapitulatif</h6>
                    <table class="table table-borderless mb-0">
                        <tr><td class="text-muted">Statut</td>
                            <td class="text-end"><span class="badge bg-@CouleurStatut(Model.Statut)">@LibelleStatut(Model.Statut)</span></td></tr>
                        <tr><td class="text-muted">Lignes</td><td class="text-end fw-bold">@Model.Lignes.Count</td></tr>
                        @if (Model.MontantPropose.HasValue)
                        {
                            <tr><td class="text-muted">Montant proposé</td>
                                <td class="text-end fw-bold text-primary fs-5">@Model.MontantPropose.Value.ToString("N0") MAD</td></tr>
                        }
                        @if (Model.DelaiLivraisonJours.HasValue)
                        {
                            <tr><td class="text-muted">Délai livraison</td>
                                <td class="text-end fw-bold">@Model.DelaiLivraisonJours j</td></tr>
                        }
                        @if (Model.ValiditeJours.HasValue && Model.DateReponse.HasValue)
                        {
                            var expire = Model.DateReponse.Value.AddDays(Model.ValiditeJours.Value);
                            <tr><td class="text-muted">Validité</td>
                                <td class="text-end small">jusqu'au @expire.ToString("dd/MM/yyyy")</td></tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
